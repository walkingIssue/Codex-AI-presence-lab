{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/walkingIssue/Codex-AI-presence/blob/main/skills/codex-voice/references/avatar-manifest.schema.json",
  "title": "Codex AI Presence avatar manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "name", "version", "entry", "capabilities"],
  "properties": {
    "schema": { "const": "codex-ai-presence/avatar/v0.1" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "minLength": 1,
      "maxLength": 64
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "entry": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9._/-]+\\.html$"
    },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["activity", "audio", "move-mode", "avatar-state-v1"] }
    }
  }
}
