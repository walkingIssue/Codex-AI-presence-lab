{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://walkingissue.local/presence/renderer-snapshot-v0.2.schema.json",
  "title": "Presence Runtime v0.2 Sanitized Renderer Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "binding_id", "revision", "avatar_ref", "model_fingerprint", "preset_ref", "semantic", "renderer", "capabilities"],
  "properties": {
    "schema": {"const": "presence/renderer-snapshot/v0.2"},
    "binding_id": {"type": "string", "format": "uuid"},
    "revision": {"type": "integer", "minimum": 1},
    "avatar_ref": {"type": "string", "minLength": 1},
    "model_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "preset_ref": {"type": ["string", "null"]},
    "semantic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["persistent_actions", "effective_actions", "activity"],
      "properties": {
        "persistent_actions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "effective_actions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "activity": {"type": ["string", "null"]}
      }
    },
    "renderer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visible", "progress_visible", "kind"],
      "properties": {
        "visible": {"type": "boolean"},
        "progress_visible": {"type": "boolean"},
        "kind": {"enum": ["builtin", "live2d"]}
      }
    },
    "capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
  }
}

